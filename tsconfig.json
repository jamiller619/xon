{
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true
  },
  "references": [
    { "path": "./packages/shared" },
    { "path": "./packages/server" },
    { "path": "./packages/plugin-sdk" },
    { "path": "./apps/desktop" },
    { "path": "./apps/headless" },
    { "path": "./plugins/tmdb-metadata" },
    { "path": "./plugins/musicbrainz-metadata" },
    { "path": "./plugins/openlibrary-metadata" },
    { "path": "./plugins/3d-model-viewer" }
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/dist",
    "**/*.test.ts",
    "**/*.spec.ts",
    "apps/web"
  ]
}
