{
  "name": "xon",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "dev": "yarn workspace @xon/headless dev & node scripts/wait-port.mjs 6019 && yarn workspace @xon/web dev",
    "typecheck": "tsc --build",
    "lint": "biome lint .",
    "format": "biome format .",
    "check": "biome check .",
    "build": "yarn workspaces run build",
    "db:rebuild": "yarn workspace @xon/server db:generate && yarn workspace @xon/server db:migrate",
    "db:reset": "DATA_DIR=apps/headless/.data node scripts/db-reset.mjs",
    "db:seed": "DATA_DIR=apps/headless/.data node scripts/db-seed.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "typescript": "^5.7.3"
  }
}
